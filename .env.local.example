# Copy this file to .env.local and fill in the values.

# PostgreSQL database URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth session secret (generate a strong random string)
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis (required for rate limiting in serverless environments)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# CSRF token (optional, not used when /api/csrf is enabled)
# NEXT_PUBLIC_CSRF_TOKEN="..."

# Public phone number shown in the UI (used in Hero/CTA links)
# NEXT_PUBLIC_PHONE_NUMBER="+15551234567"
