// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?  // for credential auth
  name      String?
  phone     String?
  role          Role     @default(USER)
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  bookings     Booking[]
  vehicles     Vehicle[]
  reviews      Review[]
  adminActions AdminAction[]
  userTokens   UserToken[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model UserToken {
  id        String   @id @default(cuid())
  userId    String
  type      String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_tokens")
}

enum Role {
  USER
  ADMIN
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  category    String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("services")
}

model Vehicle {
  id        String   @id @default(cuid())
  userId    String
  make      String
  model     String
  year      Int
  vin       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reminders Reminder[]

  @@map("vehicles")
}

model Booking {
  id        String            @id @default(cuid())
  userId    String
  serviceId String
  vehicleId String?
  specialId String?
  date      DateTime
  status    BookingStatus     @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service  @relation(fields: [serviceId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  special Special? @relation(fields: [specialId], references: [id])
  review  Review?

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Listing {
  id          String      @id @default(cuid())
  make        String
  model       String
  year        Int
  price       Float
  mileage     Int?
  fuel        String?     // Essence, Diesel, Hybride, Electrique
  transmission String?    // Manuelle, Automatique
  color       String?
  description String?
  photos      String[]    @default([])
  status      ListingStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  testDriveRequests TestDriveRequest[]

  @@map("listings")
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model TestDriveRequest {
  id           String   @id @default(cuid())
  listingId    String
  name         String
  email        String
  phone        String
  preferredAt  DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("test_drive_requests")
}

model Reminder {
  id          String   @id @default(cuid())
  vehicleId   String
  type        String
  dueDate     DateTime
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  bookingId String?  @unique
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("reviews")
}

model Special {
  id           String      @id @default(cuid())
  title        String
  description  String?
  discountType DiscountType
  discountValue Float
  code         String      @unique
  isActive     Boolean     @default(true)
  expiresAt    DateTime?
  usageLimit   Int?
  usedCount    Int         @default(0)
  createdAt    DateTime    @default(now())

  bookings Booking[]

  @@map("specials")
}

model AdminAction {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_actions")
}